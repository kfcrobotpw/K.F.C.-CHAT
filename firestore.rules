rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Hard check for the specific admin email as per user request
      return isVerified() && request.auth.token.email == 'kfcrobotpw@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isAdmin', 'isExecutive']) &&
             data.keys().size() <= 15 && 
             data.uid == (isAdmin() ? data.uid : request.auth.uid) &&
             data.email == (isAdmin() ? data.email : request.auth.token.email) &&
             data.isAdmin is bool &&
             data.isExecutive is bool &&
             (data.isAdmin == false || (isAdmin())) &&
             (data.isExecutive == false || (isAdmin()));
    }

    function isExecutiveUser() {
      return isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isExecutive == true;
    }

    // Room Validation
    function isValidRoom(data) {
      return data.participants is list &&
             data.participants.size() >= 2 &&
             request.auth.uid in data.participants &&
             data.createdAt == request.time &&
             (data.get('isExecutiveRoom', false) == false || isAdmin());
    }

    // Message Validation
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'timestamp', 'roomId']) &&
             data.keys().size() <= 10 &&
             data.text is string &&
             data.senderId == request.auth.uid &&
             data.timestamp == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isVerified() && (
        (userId == request.auth.uid && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'realName', 'studentId', 'role', 'phoneNumber'])) ||
        (isAdmin() && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'realName', 'studentId', 'role', 'isAdmin', 'isExecutive', 'warnings']))
      );
    }

    match /rooms/{roomId} {
      function isParticipant() {
         return request.auth.uid in existing().participants;
      }
      function isExecutiveRoom() {
         return existing().get('isExecutiveRoom', false) == true;
      }

      allow get: if isSignedIn() && (isParticipant() || isAdmin() || (isExecutiveRoom() && isExecutiveUser()));
      allow list: if isSignedIn(); 
      allow create: if isVerified() && isValidRoom(incoming());
      allow update: if isVerified() && (isParticipant() || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isParticipant() || isAdmin() || (isExecutiveRoom() && isExecutiveUser()));
        allow create: if isVerified() && isValidId(messageId) && (isParticipant() || isAdmin() || (isExecutiveRoom() && isExecutiveUser())) && isValidMessage(incoming());
        allow update: if false;
        allow delete: if isAdmin() || (isSignedIn() && existing().senderId == request.auth.uid);
      }
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
